generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  RECEPTIONIST
}

enum PreferredLanguage {
  EN
  KM
}

enum RoomStatus {
  AVAILABLE
  BOOKED
  OCCUPIED
  MAINTENANCE
  NEEDS_CLEANING
  CLEANING_IN_PROGRESS
}

enum HousekeepingStatus {
  NEEDS_CLEANING
  CLEANING_IN_PROGRESS
  CLEANED
  INSPECTED
  CANCELLED
}

enum HousekeepingPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum RoomType {
  SINGLE
  DOUBLE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum CoolingOption {
  FAN
  AIR_CONDITIONER
}

enum PaymentMethod {
  CASH
  CARD
  QR
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum NotificationType {
  BOOKING
  PAYMENT
  MAINTENANCE
  SYSTEM
}

enum BusinessType {
  GUESTHOUSE
  STORE
}

enum BusinessRole {
  OWNER
  ADMIN
  STAFF
}

model User {
  id                  String                   @id @default(cuid())
  name                String
  email               String                   @unique
  phone               String?
  password            String
  role                UserRole                 @default(RECEPTIONIST)
  preferredLanguage   PreferredLanguage        @default(EN)
  notifications       Notification[]
  notificationSetting UserNotificationSetting?
  ownedBusinesses     Business[]               @relation("BusinessOwner")
  businessMemberships BusinessMember[]
  sales               Sale[]                   @relation("SalesSoldBy")
  purchases           Purchase[]               @relation("PurchasesCreatedBy")
  expenses            Expense[]                @relation("ExpensesCreatedBy")
  housekeepingTasks   HousekeepingTask[]       @relation("HousekeepingAssignedTo")
  miniBarConsumptions MiniBarConsumption[]     @relation("MiniBarConsumptionsCreatedBy")
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@map("users")
}

model Room {
  id                  String               @id @default(cuid())
  roomNumber          String               @unique
  type                RoomType
  pricePerNight       Decimal              @db.Decimal(10, 2)
  status              RoomStatus           @default(AVAILABLE)
  imageUrl            String?
  bookings            Booking[]
  housekeepingTasks   HousekeepingTask[]
  miniBarConsumptions MiniBarConsumption[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?

  @@map("rooms")
}

model Guest {
  id                  String               @id @default(cuid())
  fullName            String
  phone               String
  email               String?
  idCardNumber        String?
  address             String?
  bookings            Booking[]
  miniBarConsumptions MiniBarConsumption[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@map("guests")
}

model Booking {
  id                  String               @id @default(cuid())
  guestId             String
  roomId              String
  checkInDate         DateTime
  checkOutDate        DateTime
  checkInAt           DateTime?
  checkOutAt          DateTime?
  coolingOption       CoolingOption        @default(FAN)
  roomPriceTotal      Decimal              @db.Decimal(10, 2)
  coolingPrice        Decimal              @db.Decimal(10, 2)
  totalPrice          Decimal              @db.Decimal(10, 2)
  status              BookingStatus        @default(PENDING)
  payments            Payment[]
  housekeepingTasks   HousekeepingTask[]
  miniBarConsumptions MiniBarConsumption[]
  guest               Guest                @relation(fields: [guestId], references: [id], onDelete: Restrict)
  room                Room                 @relation(fields: [roomId], references: [id], onDelete: Restrict)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([guestId])
  @@index([roomId])
  @@index([status])
  @@map("bookings")
}

model Payment {
  id        String        @id @default(cuid())
  bookingId String
  amount    Decimal       @db.Decimal(10, 2)
  method    PaymentMethod
  status    PaymentStatus @default(PENDING)
  paidAt    DateTime?
  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([bookingId])
  @@index([status])
  @@map("payments")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@map("notifications")
}

model UserNotificationSetting {
  id                String   @id @default(cuid())
  userId            String   @unique
  bookingAlerts     Boolean  @default(true)
  paymentAlerts     Boolean  @default(true)
  maintenanceAlerts Boolean  @default(true)
  systemAlerts      Boolean  @default(true)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@map("user_notification_settings")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum SaleStatus {
  COMPLETED
  CANCELLED
  REFUNDED
}

enum StorePaymentMethod {
  CASH
  CARD
  QR
  BANK_TRANSFER
}

enum PurchaseStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum ExpenseCategory {
  RENT
  ELECTRICITY
  WATER
  INTERNET
  SALARY
  MAINTENANCE
  SUPPLIES
  FOOD
  OTHER
}

enum ExpensePaymentMethod {
  CASH
  CARD
  QR
  BANK_TRANSFER
}

enum MiniBarConsumptionStatus {
  DRAFT
  CHARGED
  CANCELLED
  REFUNDED
}

model Business {
  id                       String                @id @default(uuid())
  name                     String
  type                     BusinessType
  ownerId                  String
  owner                    User                  @relation("BusinessOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members                  BusinessMember[]
  categories               ProductCategory[]
  products                 Product[]
  sales                    Sale[]
  suppliers                Supplier[]
  purchases                Purchase[]
  expenses                 Expense[]
  housekeepingTasks        HousekeepingTask[]
  miniBarConsumptions      MiniBarConsumption[]
  guesthouseStoreLink      GuesthouseStoreLink?  @relation("GuesthouseLink")
  storeLinkedByGuesthouses GuesthouseStoreLink[] @relation("StoreLink")
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  @@index([ownerId])
  @@map("businesses")
}

model ProductCategory {
  id          String    @id @default(cuid())
  businessId  String
  name        String
  description String?
  products    Product[]
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([businessId])
  @@map("product_categories")
}

model Product {
  id                      String                   @id @default(cuid())
  businessId              String
  categoryId              String?
  name                    String
  sku                     String
  barcode                 String?
  purchasePrice           Decimal                  @db.Decimal(10, 2)
  sellingPrice            Decimal                  @db.Decimal(10, 2)
  stockQuantity           Int                      @default(0)
  lowStockAlert           Int                      @default(10)
  status                  ProductStatus            @default(ACTIVE)
  business                Business                 @relation(fields: [businessId], references: [id], onDelete: Restrict)
  category                ProductCategory?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  saleItems               SaleItem[]
  purchaseItems           PurchaseItem[]
  miniBarConsumptionItems MiniBarConsumptionItem[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  deletedAt               DateTime?

  @@unique([businessId, sku])
  @@index([businessId])
  @@index([categoryId])
  @@index([status])
  @@map("products")
}

model Sale {
  id            String             @id @default(cuid())
  businessId    String
  saleNumber    String
  totalAmount   Decimal            @db.Decimal(10, 2)
  paymentMethod StorePaymentMethod
  status        SaleStatus         @default(COMPLETED)
  soldById      String
  business      Business           @relation(fields: [businessId], references: [id], onDelete: Restrict)
  soldBy        User               @relation("SalesSoldBy", fields: [soldById], references: [id], onDelete: Restrict)
  items         SaleItem[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([businessId, saleNumber])
  @@index([businessId])
  @@index([soldById])
  @@index([status])
  @@index([createdAt])
  @@map("sales")
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model BusinessMember {
  id         String       @id @default(uuid())
  businessId String
  userId     String
  role       BusinessRole
  business   Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([businessId, userId])
  @@index([businessId])
  @@index([userId])
  @@map("business_members")
}

model Supplier {
  id         String     @id @default(cuid())
  businessId String
  name       String
  phone      String?
  email      String?
  address    String?
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Restrict)
  purchases  Purchase[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([businessId])
  @@map("suppliers")
}

model Purchase {
  id             String         @id @default(cuid())
  businessId     String
  purchaseNumber String
  supplierId     String
  totalAmount    Decimal        @db.Decimal(10, 2)
  status         PurchaseStatus @default(DRAFT)
  createdById    String
  business       Business       @relation(fields: [businessId], references: [id], onDelete: Restrict)
  supplier       Supplier       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  createdBy      User           @relation("PurchasesCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  items          PurchaseItem[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([businessId, purchaseNumber])
  @@index([businessId])
  @@index([supplierId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
  @@map("purchases")
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  productId  String
  quantity   Int
  costPrice  Decimal  @db.Decimal(10, 2)
  subtotal   Decimal  @db.Decimal(10, 2)
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_items")
}

model Expense {
  id            String               @id @default(cuid())
  businessId    String
  title         String
  category      ExpenseCategory
  amount        Decimal              @db.Decimal(10, 2)
  expenseDate   DateTime
  paymentMethod ExpensePaymentMethod
  note          String?
  createdById   String
  business      Business             @relation(fields: [businessId], references: [id], onDelete: Restrict)
  createdBy     User                 @relation("ExpensesCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([businessId])
  @@index([createdById])
  @@index([category])
  @@index([expenseDate])
  @@map("expenses")
}

model HousekeepingTask {
  id           String               @id @default(cuid())
  businessId   String
  roomId       String
  assignedToId String?
  bookingId    String?
  status       HousekeepingStatus   @default(NEEDS_CLEANING)
  priority     HousekeepingPriority @default(MEDIUM)
  note         String?
  startedAt    DateTime?
  completedAt  DateTime?
  inspectedAt  DateTime?
  business     Business             @relation(fields: [businessId], references: [id], onDelete: Restrict)
  room         Room                 @relation(fields: [roomId], references: [id], onDelete: Restrict)
  assignedTo   User?                @relation("HousekeepingAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  booking      Booking?             @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([businessId])
  @@index([roomId])
  @@index([assignedToId])
  @@index([bookingId])
  @@index([status])
  @@index([priority])
  @@map("housekeeping_tasks")
}

model GuesthouseStoreLink {
  id                   String   @id @default(cuid())
  guesthouseBusinessId String   @unique
  storeBusinessId      String
  guesthouseBusiness   Business @relation("GuesthouseLink", fields: [guesthouseBusinessId], references: [id], onDelete: Cascade)
  storeBusiness        Business @relation("StoreLink", fields: [storeBusinessId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([storeBusinessId])
  @@map("guesthouse_store_links")
}

model MiniBarConsumption {
  id          String                   @id @default(cuid())
  businessId  String
  bookingId   String
  roomId      String
  guestId     String
  totalAmount Decimal                  @db.Decimal(10, 2)
  status      MiniBarConsumptionStatus @default(DRAFT)
  createdById String
  business    Business                 @relation(fields: [businessId], references: [id], onDelete: Restrict)
  booking     Booking                  @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  room        Room                     @relation(fields: [roomId], references: [id], onDelete: Restrict)
  guest       Guest                    @relation(fields: [guestId], references: [id], onDelete: Restrict)
  createdBy   User                     @relation("MiniBarConsumptionsCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  items       MiniBarConsumptionItem[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([businessId])
  @@index([bookingId])
  @@index([roomId])
  @@index([guestId])
  @@index([createdById])
  @@index([status])
  @@map("mini_bar_consumptions")
}

model MiniBarConsumptionItem {
  id            String             @id @default(cuid())
  consumptionId String
  productId     String
  quantity      Int
  unitPrice     Decimal            @db.Decimal(10, 2)
  subtotal      Decimal            @db.Decimal(10, 2)
  consumption   MiniBarConsumption @relation(fields: [consumptionId], references: [id], onDelete: Cascade)
  product       Product            @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([consumptionId])
  @@index([productId])
  @@map("mini_bar_consumption_items")
}
