generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  RECEPTIONIST
}

enum PreferredLanguage {
  EN
  KM
}

enum RoomStatus {
  AVAILABLE
  BOOKED
  OCCUPIED
  MAINTENANCE
}

enum RoomType {
  SINGLE
  DOUBLE
  TWIN
  FAMILY
  VIP
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  QR
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum NotificationType {
  BOOKING
  PAYMENT
  MAINTENANCE
  SYSTEM
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  phone         String?
  password      String
  role          UserRole       @default(RECEPTIONIST)
  preferredLanguage PreferredLanguage @default(EN)
  notifications Notification[]
  notificationSetting UserNotificationSetting?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("users")
}

model Room {
  id            String     @id @default(cuid())
  roomNumber    String     @unique
  type          RoomType
  pricePerNight Decimal    @db.Decimal(10, 2)
  status        RoomStatus @default(AVAILABLE)
  imageUrl      String?
  bookings      Booking[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  @@map("rooms")
}

model Guest {
  id           String    @id @default(cuid())
  fullName     String
  phone        String
  email        String?
  idCardNumber String?
  address      String?
  bookings     Booking[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("guests")
}

model Booking {
  id           String        @id @default(cuid())
  guestId      String
  roomId       String
  checkInDate  DateTime
  checkOutDate DateTime
  totalPrice   Decimal       @db.Decimal(10, 2)
  status       BookingStatus @default(PENDING)
  payments     Payment[]
  guest        Guest         @relation(fields: [guestId], references: [id], onDelete: Restrict)
  room         Room          @relation(fields: [roomId], references: [id], onDelete: Restrict)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([guestId])
  @@index([roomId])
  @@index([status])
  @@map("bookings")
}

model Payment {
  id        String        @id @default(cuid())
  bookingId String
  amount    Decimal       @db.Decimal(10, 2)
  method    PaymentMethod
  status    PaymentStatus @default(PENDING)
  paidAt    DateTime?
  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([bookingId])
  @@index([status])
  @@map("payments")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@map("notifications")
}

model UserNotificationSetting {
  id                String   @id @default(cuid())
  userId            String   @unique
  bookingAlerts     Boolean  @default(true)
  paymentAlerts     Boolean  @default(true)
  maintenanceAlerts Boolean  @default(true)
  systemAlerts      Boolean  @default(true)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@map("user_notification_settings")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
